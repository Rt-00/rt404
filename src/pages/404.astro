---
import BaseLayout from '../layouts/BaseLayout.astro';
import TerminalWindow from '../components/TerminalWindow.astro';
import Prompt from '../components/Prompt.astro';
import { withBase } from '../lib/url';
---

<BaseLayout title="404" description="Página não encontrada.">
  <TerminalWindow title="rt404 — error" command="cat $REQUEST_URI">
    <div class="space-y-4">
      <p class="font-mono text-term-red">
        bash: arquivo não encontrado: <span class="text-foreground"
          >No such file or directory</span
        >
      </p>
      <p class="text-3xl font-bold text-primary">404</p>
      <p class="text-sm text-muted-foreground">
        O recurso requisitado não existe ou foi movido.
      </p>
      <Prompt command="cd ~ && ls" />
      <div class="flex flex-wrap gap-4 text-sm">
        <a class="text-term-cyan hover:underline" href={withBase('/')}>~/ (home)</a>
        <a class="text-term-cyan hover:underline" href={withBase('/platform')}>
          ls platforms/
        </a>
        <a class="text-term-cyan hover:underline" href={withBase('/archive')}>
          cd archive/
        </a>
      </div>
    </div>
  </TerminalWindow>
</BaseLayout>
