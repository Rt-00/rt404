---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Prompt from '../../components/Prompt.astro';
import PlatformBadge from '../../components/PlatformBadge.astro';
import { visibleEntries } from '../../lib/collection';
import { groupByPlatform } from '../../lib/group';
import { withBase } from '../../lib/url';

const all = await getCollection('writeups');
const groups = groupByPlatform(visibleEntries(all, import.meta.env.DEV));
---

<BaseLayout title="Plataformas" description="Writeups agrupados por plataforma de CTF.">
  <Prompt class="mb-4 block" command="ls -l platforms/" />

  <h1 class="mb-6 text-2xl font-bold text-foreground">
    <span class="text-primary">#</span> Plataformas
  </h1>

  {
    groups.length === 0 ? (
      <p class="text-muted-foreground">Nenhum writeup publicado ainda.</p>
    ) : (
      <ul class="grid gap-3 sm:grid-cols-2">
        {groups.map((g) => (
          <li>
            <a
              href={withBase(`/platform/${g.platform}`)}
              class="flex items-center justify-between rounded-lg border border-border bg-card/60 p-4 transition-colors hover:border-primary/50"
            >
              <PlatformBadge platform={g.platform} />
              <span class="text-sm text-muted-foreground">
                {g.count} writeup{g.count === 1 ? '' : 's'}
              </span>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
